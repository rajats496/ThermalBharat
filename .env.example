# ThermalBharat — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── OpenWeatherMap API (REQUIRED) ────────────────────────────────
# Get free key at: https://openweathermap.org/api
# Used for: live temperature, AQI, humidity, 5-day forecast
VITE_OPENWEATHER_KEY=your_openweathermap_api_key_here

# ── Brevo (Sendinblue) Email API (OPTIONAL) ───────────────────────
# Get free key at: https://app.brevo.com → SMTP & API → API Keys
# Used for: heatwave warning email alerts to registered users
VITE_BREVO_KEY=your_brevo_api_key_here

# ── App Config ────────────────────────────────────────────────────
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
